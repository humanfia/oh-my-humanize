---
name: parallel-implementation-review
version: 1
schema: omhflow/v1
models:
  roles:
    builder: gpt-5.5
    reviewer: gpt-5.5
  defaults:
    agent: builder
    review: reviewer
  unavailable: fallback-to-parent
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Parallel implementation review

```yaml workflow
resources:
  - path: scripts/precheck-task-contract.js
    kind: script
  - path: scripts/materialize-plan-handoff.js
    kind: script
  - path: scripts/run-declared-validation.js
    kind: script
  - path: scripts/lane-hard-stop-guard.js
    kind: script
  - path: scripts/materialize-integration-review.js
    kind: script
  - path: scripts/finalize-rollback-coverage.js
    kind: script
  - path: scripts/evidence-contract-guard.js
    kind: script
  - path: scripts/materialize-strong-review-packet.js
    kind: script
  - path: scripts/finalize-strong-review.js
    kind: script
  - path: prompts/scope.md
    kind: prompt
  - path: prompts/implement-core.md
    kind: prompt
  - path: prompts/implement-tests.md
    kind: prompt
  - path: prompts/implement-docs.md
    kind: prompt
  - path: prompts/integration-review.md
    kind: prompt
  - path: prompts/strong-review.md
    kind: prompt
capabilities:
  tools:
    - eval
  agents:
    - task
    - reviewer
sequence:
  - node:
      id: precheckTaskContract
      type: script
      script:
        language: js
        file: scripts/precheck-task-contract.js
      writes:
        - /taskContract
        - /runtime
  - node:
      id: scope
      type: agent
      agent: task
      model:
        role: builder
      reads:
        - /taskContract
      prompt:
        template:
          file: prompts/scope.md
          bindings:
            taskContract:
              state: /taskContract
      writes:
        - /plan
  - node:
      id: materializePlanHandoff
      type: script
      script:
        language: js
        file: scripts/materialize-plan-handoff.js
      reads:
        - /plan
      writes:
        - /planHandoff
  - parallel:
      - node:
          id: implementCore
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /planHandoff
            - /taskContract
          prompt:
            template:
              file: prompts/implement-core.md
              bindings:
                planHandoff:
                  state: /planHandoff
                taskContract:
                  state: /taskContract
      - node:
          id: implementTests
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /planHandoff
            - /taskContract
          prompt:
            template:
              file: prompts/implement-tests.md
              bindings:
                planHandoff:
                  state: /planHandoff
                taskContract:
                  state: /taskContract
      - node:
          id: implementDocs
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /planHandoff
            - /taskContract
          prompt:
            template:
              file: prompts/implement-docs.md
              bindings:
                planHandoff:
                  state: /planHandoff
                taskContract:
                  state: /taskContract
    join:
      id: laneHardStopGuard
      type: script
      script:
        language: js
        file: scripts/lane-hard-stop-guard.js
      writes:
        - /laneHardStopGuard
  - node:
      id: integrationReview
      type: agent
      agent: task
      model:
        role: reviewer
      reads:
        - /planHandoff
        - /taskContract
        - /summary
        - /laneHardStopGuard
      prompt:
        template:
          file: prompts/integration-review.md
          bindings:
            planHandoff:
              state: /planHandoff
            taskContract:
              state: /taskContract
            coreSummary:
              state: /laneHardStopGuard/lane_summaries/implementCore
            testsSummary:
              state: /laneHardStopGuard/lane_summaries/implementTests
            docsSummary:
              state: /laneHardStopGuard/lane_summaries/implementDocs
  - node:
      id: materializeIntegrationReview
      type: script
      script:
        language: js
        file: scripts/materialize-integration-review.js
      reads:
        - /planHandoff
        - /taskContract
        - /summary
        - /laneHardStopGuard
      writes:
        - /integrationReviewArtifact
        - /reviewHandoff
  - node:
      id: runDeclaredValidation
      type: script
      script:
        language: js
        timeoutMs: 3600000
        file: scripts/run-declared-validation.js
      writes:
        - /declaredValidation
  - node:
      id: finalizeRollbackCoverage
      type: script
      script:
        language: js
        file: scripts/finalize-rollback-coverage.js
      writes:
        - /rollbackCoverage
  - node:
      id: evidenceContractGuard
      type: script
      script:
        language: js
        file: scripts/evidence-contract-guard.js
      reads:
        - /planHandoff
        - /laneHardStopGuard
        - /reviewHandoff
      writes:
        - /evidenceContract
  - node:
      id: materializeStrongReviewPacket
      type: script
      script:
        language: js
        file: scripts/materialize-strong-review-packet.js
      reads:
        - /planHandoff
        - /taskContract
        - /reviewHandoff
        - /evidenceContract
      writes:
        - /strongReviewPacket
  - node:
      id: strongReview
      type: review
      agent: reviewer
      model:
        role: reviewer
      reads:
        - /strongReviewPacket
      prompt:
        template:
          file: prompts/strong-review.md
          bindings:
            strongReviewPacket:
              state: /strongReviewPacket
      gates:
        - reject
        - promote
      fallbackVerdict: reject
      writes:
        - /verdict
  - node:
      id: finalizeStrongReview
      type: script
      script:
        language: js
        file: scripts/finalize-strong-review.js
      reads:
        - /verdict
        - /evidenceContract
      writes:
        - /finalReview
```
