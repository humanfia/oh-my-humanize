---
name: parallel-implementation-review
version: 1
schema: omhflow/v1
models:
  roles:
    builder: gpt-5.5
    reviewer: gpt-5.5
  defaults:
    agent: builder
    review: reviewer
  unavailable: fallback-to-parent
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Parallel implementation review

```yaml workflow
resources:
  - path: scripts/precheck-task-contract.js
    kind: script
  - path: scripts/run-declared-validation.js
    kind: script
  - path: scripts/lane-hard-stop-guard.js
    kind: script
  - path: scripts/materialize-integration-review.js
    kind: script
  - path: scripts/evidence-contract-guard.js
    kind: script
  - path: scripts/finalize-strong-review.js
    kind: script
  - path: prompts/scope.md
    kind: prompt
  - path: prompts/implement-core.md
    kind: prompt
  - path: prompts/implement-tests.md
    kind: prompt
  - path: prompts/implement-docs.md
    kind: prompt
  - path: prompts/integration-review.md
    kind: prompt
  - path: prompts/strong-review.md
    kind: prompt
capabilities:
  tools:
    - eval
  agents:
    - task
    - reviewer
sequence:
  - node:
      id: precheckTaskContract
      type: script
      script:
        language: js
        file: scripts/precheck-task-contract.js
      writes:
        - /taskContract
        - /runtime
  - node:
      id: scope
      type: agent
      agent: task
      model:
        role: builder
      reads:
        - /taskContract
      prompt:
        template:
          file: prompts/scope.md
          bindings:
            taskContract:
              state: /taskContract
      writes:
        - /plan
  - parallel:
      - node:
          id: implementCore
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
            - /taskContract
          prompt:
            template:
              file: prompts/implement-core.md
              bindings:
                plan:
                  state: /plan
                taskContract:
                  state: /taskContract
      - node:
          id: implementTests
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
            - /taskContract
          prompt:
            template:
              file: prompts/implement-tests.md
              bindings:
                plan:
                  state: /plan
                taskContract:
                  state: /taskContract
      - node:
          id: implementDocs
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
            - /taskContract
          prompt:
            template:
              file: prompts/implement-docs.md
              bindings:
                plan:
                  state: /plan
                taskContract:
                  state: /taskContract
    join:
      id: laneHardStopGuard
      type: script
      script:
        language: js
        file: scripts/lane-hard-stop-guard.js
      writes:
        - /laneHardStopGuard
  - node:
      id: integrationReview
      type: agent
      agent: reviewer
      model:
        role: reviewer
      reads:
        - /plan
        - /taskContract
        - /summary
        - /laneHardStopGuard
      prompt:
        template:
          file: prompts/integration-review.md
          bindings:
            plan:
              state: /plan
            taskContract:
              state: /taskContract
            coreSummary:
              output:
                node: implementCore
                path: /summary
                activation: latest-completed
            testsSummary:
              output:
                node: implementTests
                path: /summary
                activation: latest-completed
            docsSummary:
              output:
                node: implementDocs
                path: /summary
                activation: latest-completed
  - node:
      id: materializeIntegrationReview
      type: script
      script:
        language: js
        file: scripts/materialize-integration-review.js
      reads:
        - /plan
        - /taskContract
        - /summary
        - /laneHardStopGuard
      writes:
        - /integrationReviewArtifact
  - node:
      id: runDeclaredValidation
      type: script
      script:
        language: js
        timeoutMs: 3600000
        file: scripts/run-declared-validation.js
      writes:
        - /declaredValidation
  - node:
      id: evidenceContractGuard
      type: script
      script:
        language: js
        file: scripts/evidence-contract-guard.js
      writes:
        - /evidenceContract
  - node:
      id: strongReview
      type: review
      agent: reviewer
      model:
        role: reviewer
      reads:
        - /plan
        - /taskContract
        - /summary
        - /evidenceContract
      prompt:
        template:
          file: prompts/strong-review.md
          bindings:
            plan:
              state: /plan
            taskContract:
              state: /taskContract
            coreSummary:
              output:
                node: implementCore
                path: /summary
                activation: latest-completed
            testsSummary:
              output:
                node: implementTests
                path: /summary
                activation: latest-completed
            docsSummary:
              output:
                node: implementDocs
                path: /summary
                activation: latest-completed
            integrationSummary:
              output:
                node: integrationReview
                path: /summary
                activation: latest-completed
            evidenceContract:
              state: /evidenceContract
      gates:
        - reject
        - promote
      fallbackVerdict: reject
      writes:
        - /verdict
  - node:
      id: finalizeStrongReview
      type: script
      script:
        language: js
        file: scripts/finalize-strong-review.js
      reads:
        - /verdict
        - /evidenceContract
      writes:
        - /finalReview
```
