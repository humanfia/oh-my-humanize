---
name: human-interactive-dev
version: 3
schema: omhflow/v1
checkpoint:
  stopDeadlineMs: 1000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Human Interactive Developer Flow

```yaml workflow
stateSchema:
  version: 1
  shape:
    phase: string
    selected: string
    verdict: string
resources:
  - path: scripts/plan.sh
    kind: script
  - path: scripts/human-intervention.sh
    kind: script
  - path: scripts/reset-artifacts.sh
    kind: script
  - path: scripts/implementation.sh
    kind: script
  - path: scripts/candidate-a.sh
    kind: script
  - path: scripts/candidate-b.sh
    kind: script
  - path: scripts/evaluate.sh
    kind: script
  - path: scripts/refine.sh
    kind: script
  - path: scripts/loop-decision.sh
    kind: script
  - path: scripts/final-check.sh
    kind: script
capabilities:
  tools:
    - bash
nodes:
  plan:
    type: script
    script:
      language: sh
      file: scripts/plan.sh
    writes:
      - /phase
  humanIntervention:
    type: script
    script:
      language: sh
      file: scripts/human-intervention.sh
    reads:
      - /phase
    writes:
      - /phase
  resetArtifacts:
    type: script
    script:
      language: sh
      file: scripts/reset-artifacts.sh
    reads:
      - /phase
    writes:
      - /phase
  implementation:
    type: script
    script:
      language: sh
      file: scripts/implementation.sh
    reads:
      - /phase
    writes:
      - /phase
  candidateA:
    type: script
    script:
      language: sh
      file: scripts/candidate-a.sh
    reads:
      - /phase
  candidateB:
    type: script
    script:
      language: sh
      file: scripts/candidate-b.sh
    reads:
      - /phase
  evaluate:
    type: script
    script:
      language: sh
      file: scripts/evaluate.sh
    writes:
      - /selected
  refine:
    type: script
    script:
      language: sh
      file: scripts/refine.sh
  loopDecision:
    type: script
    script:
      language: sh
      file: scripts/loop-decision.sh
    writes:
      - /verdict
  finalCheck:
    type: script
    script:
      language: sh
      file: scripts/final-check.sh
edges:
  - from: plan
    to: humanIntervention
  - from: humanIntervention
    to: resetArtifacts
  - from: resetArtifacts
    to: implementation
  - from: implementation
    to: candidateA
  - from: implementation
    to: candidateB
  - from: candidateA
    to: evaluate
  - from: candidateB
    to: evaluate
  - from: evaluate
    to: refine
  - from: refine
    to: loopDecision
  - from: loopDecision
    to: refine
    when: state.verdict == "retry"
  - from: loopDecision
    to: finalCheck
    when: state.verdict == "finish"
```
