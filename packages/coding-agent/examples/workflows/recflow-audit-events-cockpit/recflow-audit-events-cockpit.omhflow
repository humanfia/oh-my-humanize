---
name: recflow-audit-events-cockpit
version: 1
schema: omhflow/v1
resourceDir: recflow-audit-events-cockpit
models:
  roles:
    builder: gpt-5.5
    reviewer: gpt-5.5
  defaults:
    agent: builder
    review: reviewer
  unavailable: fallback-to-parent
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
compatibility:
  omp: ">=15.12.5"
---
# Recflow Audit Events Cockpit

Live OMH validation flow for extending a recursive workflow runner with
inspectable execution events.

```yaml workflow
imports:
  quality:
    path: ./recflow-audit-events-cockpit/quality-subflow.omhflow
stateSchema:
  version: 1
  shape:
    validation: object
    verdict: string
    quality: object
    archive: object
resources:
  - path: scripts/bootstrap-extension.sh
    kind: script
  - path: scripts/inspect-contract.sh
    kind: script
  - path: scripts/static-probe.sh
    kind: script
  - path: scripts/run-tests.sh
    kind: script
  - path: scripts/archive-evidence.sh
    kind: script
  - path: prompts/build-engine-events.md
    kind: prompt
  - path: prompts/build-cli-events.md
    kind: prompt
  - path: prompts/fix-round.md
    kind: prompt
  - path: prompts/review-round.md
    kind: prompt
  - path: seed/recflow-lab/README.md
    kind: data
  - path: seed/recflow-lab/package.json
    kind: data
  - path: seed/recflow-lab/src/cli.ts
    kind: data
  - path: seed/recflow-lab/src/engine.ts
    kind: data
  - path: seed/recflow-lab/src/types.ts
    kind: data
  - path: seed/recflow-lab/test/cli.test.ts
    kind: data
  - path: seed/recflow-lab/test/engine.test.ts
    kind: data
capabilities:
  agents:
    - task
    - reviewer
  tools:
    - bash
sequence:
  - node:
      id: bootstrapExtension
      type: script
      script:
        language: sh
        file: scripts/bootstrap-extension.sh
      writes:
        - /validation
  - node:
      id: inspectContract
      type: script
      reads:
        - /validation
      script:
        language: sh
        file: scripts/inspect-contract.sh
      writes:
        - /validation
  - parallel:
      - node:
          id: buildEngineEvents
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /validation
          prompt:
            file: prompts/build-engine-events.md
      - node:
          id: buildCliEvents
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /validation
          prompt:
            file: prompts/build-cli-events.md
      - node:
          id: staticProbe
          type: script
          reads:
            - /validation
          script:
            language: sh
            file: scripts/static-probe.sh
          writes:
            - /validation/staticProbe
    join:
      id: runValidation
      type: script
      reads:
        - /validation
      script:
        language: sh
        file: scripts/run-tests.sh
      writes:
        - /validation
  - template:
      kind: retry_until
      body:
        sequence:
          - node:
              id: fixRound
              type: agent
              agent: task
              model:
                role: builder
              reads:
                - /validation
              prompt:
                template:
                  file: prompts/fix-round.md
                  bindings:
                    validationStatus:
                      state: /validation/status
                    validationRound:
                      state: /validation/round
                    validationSummary:
                      state: /validation/summary
                    validationLog:
                      state: /validation/testLog
          - node:
              id: runValidationAfterFix
              type: script
              reads:
                - /validation
              script:
                language: sh
                file: scripts/run-tests.sh
              writes:
                - /validation
      review:
        id: reviewAuditEvents
        type: review
        agent: reviewer
        model:
          role: reviewer
        reads:
          - /validation
        prompt:
          template:
            file: prompts/review-round.md
            bindings:
              validationStatus:
                state: /validation/status
              validationRound:
                state: /validation/round
              validationSummary:
                state: /validation/summary
              validationLog:
                state: /validation/testLog
        writes:
          - /verdict
        gates:
          - CONTINUE
          - COMPLETE
        fallbackVerdict: CONTINUE
      retryWhen: outputs.reviewAuditEvents.verdict == "CONTINUE"
  - use: quality
  - node:
      id: archiveEvidence
      type: script
      reads:
        - /validation
        - /quality
        - /verdict
      script:
        language: sh
        file: scripts/archive-evidence.sh
      writes:
        - /archive
```
