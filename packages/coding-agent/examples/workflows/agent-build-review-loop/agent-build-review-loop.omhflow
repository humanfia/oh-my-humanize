---
name: agent-build-review-loop
version: 1
schema: omhflow/v1
models:
  roles:
    builder: gpt-5.5
    reviewer: gpt-5.5
  defaults:
    agent: builder
    review: reviewer
  unavailable: fallback-to-parent
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Agent Build/Review Loop

```yaml workflow
stateSchema:
  version: 1
  shape:
    progress: object
    implementation: object
    verdict: string
    archive: object
resources:
  - path: scripts/initialize-loop.js
    kind: script
  - path: scripts/archive-loop.js
    kind: script
  - path: prompts/build-round.md
    kind: prompt
  - path: prompts/review-round.md
    kind: prompt
capabilities:
  tools:
    - eval
    - bash
  agents:
    - task
    - reviewer
sequence:
  - node:
      id: initializeLoop
      type: script
      script:
        language: js
        file: scripts/initialize-loop.js
      writes:
        - /progress
  - template:
      kind: retry_until
      body:
        node:
          id: buildRound
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /progress
          prompt:
            file: prompts/build-round.md
          writes:
            - /implementation
      review:
        id: reviewRound
        type: review
        agent: reviewer
        model:
          role: reviewer
        reads:
          - /progress
          - /implementation
        prompt:
          file: prompts/review-round.md
        writes:
          - /verdict
        gates:
          - complete
          - continue
        fallbackVerdict: continue
      retryWhen: outputs.reviewRound.verdict == "continue"
  - node:
      id: archiveLoop
      type: script
      reads:
        - /verdict
      script:
        language: js
        file: scripts/archive-loop.js
      writes:
        - /archive
```
