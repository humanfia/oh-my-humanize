---
name: parallel-implementation-review
version: 1
schema: omhflow/v1
models:
  roles:
    builder: gpt-5.5
    reviewer: gpt-5.5
  defaults:
    agent: builder
    review: reviewer
  unavailable: fallback-to-parent
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Parallel implementation review

```yaml workflow
resources:
  - path: scripts/precheck-task-contract.js
    kind: script
  - path: prompts/scope.md
    kind: prompt
  - path: prompts/implement-core.md
    kind: prompt
  - path: prompts/implement-tests.md
    kind: prompt
  - path: prompts/implement-docs.md
    kind: prompt
  - path: prompts/integration-review.md
    kind: prompt
  - path: prompts/strong-review.md
    kind: prompt
capabilities:
  tools:
    - eval
  agents:
    - task
    - reviewer
sequence:
  - node:
      id: precheckTaskContract
      type: script
      script:
        language: js
        file: scripts/precheck-task-contract.js
      writes:
        - /taskContract
  - node:
      id: scope
      type: agent
      agent: task
      model:
        role: builder
      reads:
        - /taskContract
      prompt:
        template:
          file: prompts/scope.md
          bindings:
            taskContract:
              state: /taskContract
      writes:
        - /plan
  - parallel:
      - node:
          id: implementCore
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
            - /taskContract
          prompt:
            template:
              file: prompts/implement-core.md
              bindings:
                plan:
                  state: /plan
                taskContract:
                  state: /taskContract
      - node:
          id: implementTests
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
            - /taskContract
          prompt:
            template:
              file: prompts/implement-tests.md
              bindings:
                plan:
                  state: /plan
                taskContract:
                  state: /taskContract
      - node:
          id: implementDocs
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
            - /taskContract
          prompt:
            template:
              file: prompts/implement-docs.md
              bindings:
                plan:
                  state: /plan
                taskContract:
                  state: /taskContract
    join:
      id: integrationReview
      type: review
      agent: reviewer
      model:
        role: reviewer
      reads:
        - /plan
        - /taskContract
      prompt:
        template:
          file: prompts/integration-review.md
          bindings:
            plan:
              state: /plan
            taskContract:
              state: /taskContract
      gates:
        - reviewed
  - node:
      id: strongReview
      type: review
      agent: reviewer
      model:
        role: reviewer
      reads:
        - /plan
        - /taskContract
      prompt:
        template:
          file: prompts/strong-review.md
          bindings:
            plan:
              state: /plan
            taskContract:
              state: /taskContract
      gates:
        - reject
        - promote
```
